{
  "source_name": "MIT Technology Review",
  "base_url": "https://www.elancasti.com.ar/",
  "news_page_url": "https://www.elancasti.com.ar/",
  "use_rss": false,
  "rss_url": "",
  "scraping_config": {
    "container_selector": "article", 
    "title_selector": "h3 a, h2 a, .title a",
    "link_selector": "a",
    "summary_selector": "p, .summary, .excerpt",
    "date_selector": "time, .date",
    "max_articles_to_process": 3
  },
  "content_extraction": {
    "extract_full_content": true,
    "body_selector": "article body, .post-content, .entry-content, main article"
  }
}
